# 外卖系统环境变量配置文件
# 复制此文件为 .env 并根据实际情况修改配置值

# ============================================
# MySQL 数据库配置
# ============================================

# MySQL root 用户密码（必填）
# 建议使用强密码，包含大小写字母、数字和特殊字符
MYSQL_ROOT_PASSWORD=root123456

# MySQL 数据库名称（可选，默认：food_delivery）
MYSQL_DATABASE=food_delivery

# MySQL 普通用户名（可选，默认：fooduser）
MYSQL_USER=fooduser

# MySQL 普通用户密码（可选，默认：foodpass123）
MYSQL_PASSWORD=foodpass123

# ============================================
# Spring Boot 数据源配置
# ============================================

# 数据库用户名（可选，默认：root）
# 注意：如果使用非 root 用户，需要确保该用户有足够权限
SPRING_DATASOURCE_USERNAME=root

# 数据库密码（可选，默认与 MYSQL_ROOT_PASSWORD 一致）
SPRING_DATASOURCE_PASSWORD=root123456

# ============================================
# JWT 配置
# ============================================

# JWT 密钥（必填，生产环境必须修改！）
# 要求：至少 256 位（32 个字符），建议使用随机生成的字符串
# 警告：生产环境请勿使用示例值！
# 可以使用以下命令生成安全的密钥：
# openssl rand -base64 32
JWT_SECRET=food-delivery-secret-key-must-be-at-least-256-bits-long-for-hs256

# JWT Token 过期时间（可选，默认：86400000 毫秒 = 24 小时）
# 单位：毫秒
JWT_EXPIRATION=86400000

# ============================================
# 文件上传配置
# ============================================

# 文件上传路径（可选，默认：./uploads/）
# 本地开发时使用相对路径，Docker 部署时使用容器内路径
FILE_UPLOAD_PATH=./uploads/

# ============================================
# 配置说明
# ============================================
#
# 1. 所有配置项都有默认值，标记为"必填"的项建议在生产环境修改
# 2. 本地开发时，如果不创建 .env 文件，将使用默认值
# 3. Docker 部署时，docker-compose.yml 会自动读取 .env 文件
# 4. 生产环境必须修改以下配置：
#    - MYSQL_ROOT_PASSWORD
#    - JWT_SECRET
#
# ============================================
